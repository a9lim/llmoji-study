# build / editable install artifacts
*.egg-info/
dist/
build/
__pycache__/
*.pyc

# pilot outputs — committed so findings are readable from the repo,
# regenerable with the scripts for anyone with the model cached.

# hidden-state sidecars — ~50 MB per generation × ~1500 generations
# = way too big for git. Regenerable from the pilot/emotional runners
# with the model cached. Local-only by design.
data/hidden/

# local envs
.venv/
.env

# run logs — ad-hoc tee'd output, not part of the experimental record
logs/

# editor cruft
.DS_Store
.idea/
.vscode/
.claude/

# Snapshot of the contributor-submitted HF dataset
# (a9lim/llmoji); regenerable via scripts/06_claude_hf_pull.py.
data/hf_dataset/

# Multi-layer h_mean tensors for the v3 follow-on analyses
# (scripts 21, 23). ~800 MB per model (npz compression doesn't help
# with dense float32 hidden states); one-shot rebuild from the
# data/hidden/<experiment>/*.npz sidecars via the loader's
# cache_path arg.
data/cache/
